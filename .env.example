# Supabase Configuration
# Get these values from your Supabase project dashboard:
# Settings → Chaves de API (API Keys)

# Project URL (ex: https://xxxxxxxxxxx.supabase.co)
VITE_SUPABASE_URL=your_supabase_project_url

# Chave publicável / Publishable Key (começa com sb_publishable_...)
# ⚠️ NÃO use a chave secreta!
VITE_SUPABASE_ANON_KEY=your_supabase_publishable_key

# Optional: Para usar o modo de desenvolvimento com localStorage
# Deixe em branco ou "false" para usar Supabase
# Defina como "true" para usar LocalStorage (MVP)
VITE_USE_LOCAL_STORAGE=true
