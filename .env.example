# ============================================================================
# SUPABASE CONFIGURATION
# ============================================================================
# Get these values from your Supabase project:
# Dashboard → Settings → API

# Your Supabase project URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anon/public key (safe to expose in frontend)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================================
# PWA PUSH NOTIFICATIONS — VAPID
# ============================================================================
# Generate keys once with: npx web-push generate-vapid-keys
#
# VITE_VAPID_PUBLIC_KEY → safe to expose in frontend (used for push subscription)
# VAPID_PRIVATE_KEY     → MUST be set as Supabase Secret, NEVER in frontend
# VAPID_SUBJECT         → mailto: or https: identifier for your app
#
# Generated keys (example — generate your own):
#   Public Key:  BG_RArbkI36185Ij5wUa0ZkDbwLSNhgaJTcaSTdrJ6cfsn8AhW6ZziHLG1UYKGN7-lwtOH4AbRJQiKEaXayWfE8
#   Private Key: VMybdoqIzJ5QZNSmwsqP2bR-ALc3UQgZmwcdMc69btw  (Supabase secret only!)
#
# To configure in Supabase:
#   supabase secrets set VAPID_PUBLIC_KEY=<sua_chave_publica>
#   supabase secrets set VAPID_PRIVATE_KEY=<sua_chave_privada>
#   supabase secrets set VAPID_SUBJECT=mailto:suporte@pocketwise.app

VITE_VAPID_PUBLIC_KEY=BG_RArbkI36185Ij5wUa0ZkDbwLSNhgaJTcaSTdrJ6cfsn8AhW6ZziHLG1UYKGN7-lwtOH4AbRJQiKEaXayWfE8

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Set to "true" to use localStorage (dev mode without Supabase)
# Set to "false" to use Supabase (production mode)
VITE_USE_LOCAL_STORAGE=false

# ============================================================================
# PAYMENT - ASAAS (Configurar como Supabase Secrets, NÃO no frontend)
# ============================================================================
# IMPORTANTE: As variáveis abaixo são usadas APENAS nas Supabase Edge Functions.
# Elas devem ser configuradas como secrets no Supabase, NÃO no .env do frontend.
#
# Para configurar no Supabase:
#   supabase secrets set ASAAS_API_KEY=seu_token_aqui
#   supabase secrets set ASAAS_ENVIRONMENT=sandbox
#   supabase secrets set ASAAS_WEBHOOK_TOKEN=seu_token_webhook_aqui
#
# ASAAS_API_KEY=              # Token da API Asaas (Minha Conta → Integrações → API)
# ASAAS_ENVIRONMENT=sandbox   # "sandbox" para testes, "production" para produção
# ASAAS_WEBHOOK_TOKEN=        # Token personalizado para validar webhooks (opcional)

# ============================================================================
# ANALYTICS (Optional - for future implementation)
# ============================================================================

# PostHog Configuration
# VITE_POSTHOG_KEY=phc_...
# VITE_POSTHOG_HOST=https://app.posthog.com

# Google Analytics
# VITE_GA_MEASUREMENT_ID=G-...

# ============================================================================
# INSTRUCTIONS
# ============================================================================
# 1. Copy this file to .env.local
# 2. Replace the placeholder values with your actual credentials
# 3. Never commit .env.local to Git (it's already in .gitignore)
# 4. Restart your dev server after changing env variables: npm run dev
#
# For production (Vercel):
# Add these variables in Vercel Dashboard → Settings → Environment Variables
